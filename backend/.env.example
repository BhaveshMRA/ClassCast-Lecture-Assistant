# === OpenRouter ===
# Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Fast path — concept extraction + summaries (~free tier)
OPENROUTER_FLASH_MODEL=google/gemini-2.0-flash-exp:free
# Slow path — animated HTML visuals (higher quality)
OPENROUTER_PRO_MODEL=google/gemini-2.5-pro-preview-03-25

# === Whisper (Step 2) ===
WHISPER_MODEL=base       # tiny | base | small | medium | large
WHISPER_DEVICE=cpu       # cpu | cuda
WHISPER_COMPUTE_TYPE=int8

# === Pipeline (Step 3) ===
BATCH_SENTENCE_COUNT=2
BATCH_TIMEOUT_SECONDS=8.0
CONCEPT_CONFIDENCE_THRESHOLD=0.5

# === Server ===
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
